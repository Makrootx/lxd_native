# LXD Cluster Configuration
# Format: KEY=VALUE  (#-prefixed lines and blank lines are ignored)
# This file is loaded by config.py at import time.
# Copy to .env_lxd and adjust before running main.py.
#

LXD_CONCURRENCY=6

# ── Remote LXD server ─────────────────────────────────────────────────────────
# Leave blank to connect via the local Unix socket
# (default when LXD is installed on the same machine).
# Set to https://hostname-or-ip:8443 for a remote LXD server.
LXD_ENDPOINT=

# Cluster placement: target cluster member for new containers.
# Leave blank to use the local hostname (auto-detected at runtime).
# Set to a specific member name (e.g. vm2) to place containers there.
# The master host must have the container image stored locally, so the
# default (local hostname) is the safest choice unless images are
# pre-distributed to all cluster members.
LXD_TARGET=

# TLS client certificate and key for authenticating to a remote LXD server.
# Generate with:  lxc remote generate-certificate
# Absolute paths to PEM files.
LXD_CERT=
LXD_KEY=

# CA certificate to verify the remote LXD server's TLS certificate.
# Leave blank to use system CAs (or set to "false" to skip verification — dev only).
LXD_CA=
